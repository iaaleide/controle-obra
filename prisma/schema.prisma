generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Perfil {
  ADMIN
  MESTRE
  VISITANTE
}

enum AcaoPresencaHistorico {
  CRIACAO
  ALTERACAO
}

enum TipoCustoFuncionario {
  CARGO
  PESSOA
}

enum ModoGraficoMedicao {
  POR_SERVICO
  CONSOLIDADO
}

enum TipoRelatorio {
  MEDICAO
  FOTOGRAFICO
}

model Usuario {
  id           String   @id @default(cuid())
  login        String   @unique
  senhaHash    String
  nome         String
  email        String?
  telefone     String?
  perfil       Perfil   @default(VISITANTE)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  resetTokens        PasswordReset[]
  historicoPresencas PresencaHistorico[]
  obrasAlocadas      UsuarioObra[]
}

model Obra {
  id           String   @id @default(cuid())
  nome         String
  clienteNome  String?
  endereco     String?
  descricao    String?
  ativa        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  alocacoes   FuncionarioObra[]
  presencas   Presenca[]
  visitantes  UsuarioObra[]
  diarios     DiarioObra[]
  emprestimos FerramentaEmprestimo[]
  relatorios  Relatorio[]
}

model UsuarioObra {
  usuarioId String
  obraId    String
  criadoEm  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  obra    Obra    @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@id([usuarioId, obraId])
  @@index([obraId])
}

model Funcionario {
  id           String   @id @default(cuid())
  nome         String
  cargo        String?
  rg           String?
  cpf          String?  @unique
  endereco     String?
  telefone     String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  obras     FuncionarioObra[]
  presencas Presenca[]
  custos    CustoFuncionario[]
}

model FuncionarioObra {
  funcionarioId String
  obraId        String
  criadoEm      DateTime @default(now())

  funcionario Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  obra        Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@id([funcionarioId, obraId])
  @@index([obraId])
}

model Presenca {
  id            String   @id @default(cuid())
  funcionarioId String
  obraId        String
  data          DateTime @db.Date
  presente      Boolean  @default(false)
  observacao    String?  @db.VarChar(500)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  funcionario Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  obra        Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)
  historico   PresencaHistorico[]

  @@unique([funcionarioId, data])
  @@index([obraId, data])
}

model PresencaHistorico {
  id                 String                @id @default(cuid())
  presencaId         String
  funcionarioId      String
  obraId             String
  data               DateTime              @db.Date
  presente           Boolean
  observacao         String?               @db.VarChar(500)
  acao               AcaoPresencaHistorico
  usuarioId          String
  usuarioNome        String
  usuarioPerfil      Perfil
  presenteAnterior   Boolean?
  observacaoAnterior String?               @db.VarChar(500)
  obraIdAnterior     String?
  criadoEm           DateTime              @default(now())

  presenca Presenca @relation(fields: [presencaId], references: [id], onDelete: Cascade)
  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([presencaId])
  @@index([funcionarioId, data])
}

model CustoFuncionario {
  id            String               @id @default(cuid())
  tipo          TipoCustoFuncionario
  cargo         String?
  funcionarioId String?
  valorDiario   Decimal              @db.Decimal(10, 2)
  ativo         Boolean              @default(true)
  criadoEm      DateTime             @default(now())
  atualizadoEm  DateTime             @updatedAt

  funcionario Funcionario? @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@index([tipo, cargo])
  @@index([funcionarioId])
}

model DiarioObra {
  id          String   @id @default(cuid())
  obraId      String
  data        DateTime @db.Date
  clienteNome String?
  clima       String?
  observacoes String?  @db.Text
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  obra  Obra             @relation(fields: [obraId], references: [id], onDelete: Cascade)
  fotos DiarioObraFoto[]

  @@index([obraId, data])
}

model DiarioObraFoto {
  id           String  @id @default(cuid())
  diarioId     String
  pagina       Int     @default(0)
  ordem        Int
  imagemBase64 String? @db.Text
  legenda      String? @db.Text

  diario DiarioObra @relation(fields: [diarioId], references: [id], onDelete: Cascade)

  @@index([diarioId])
}

model Ferramenta {
  id           String   @id @default(cuid())
  nome         String
  descricao    String?
  ativa        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  emprestimos FerramentaEmprestimo[]
}

model FerramentaEmprestimo {
  id            String    @id @default(cuid())
  ferramentaId  String
  obraId        String
  dataDeixada   DateTime  @db.Date
  dataDevolvida DateTime? @db.Date
  observacao    String?
  criadoEm      DateTime  @default(now())

  ferramenta Ferramenta @relation(fields: [ferramentaId], references: [id], onDelete: Cascade)
  obra       Obra       @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@index([obraId])
  @@index([ferramentaId])
}

model Relatorio {
  id                String             @id @default(uuid()) @db.Uuid
  obraId            String             @map("obra_id")
  tipo              TipoRelatorio      @default(MEDICAO)
  periodoInicio     DateTime           @map("periodo_inicio") @db.Date
  periodoFim        DateTime           @map("periodo_fim") @db.Date
  acumuladoTotal    Decimal?           @map("acumulado_total") @db.Decimal(14, 2)
  observacoesGerais String?            @map("observacoes_gerais") @db.Text
  modoGrafico       ModoGraficoMedicao @default(POR_SERVICO) @map("modo_grafico")
  opcoesPdfMedicao  Json?              @map("opcoes_pdf_medicao")
  clienteNome       String?            @map("cliente_nome")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  obra  Obra            @relation(fields: [obraId], references: [id], onDelete: Cascade)
  itens ItemRelatorio[]
  fotos FotoRelatorio[]

  @@index([obraId, periodoInicio])
  @@map("relatorios")
}

model ItemRelatorio {
  id                  String  @id @default(uuid()) @db.Uuid
  relatorioId         String  @map("relatorio_id") @db.Uuid
  ordem               Int
  item                String?
  descricao           String
  valorTotal          Decimal @map("valor_total") @db.Decimal(14, 2)
  valorPrevisto       Decimal @map("valor_previsto") @db.Decimal(14, 2)
  valorRealizado      Decimal @map("valor_realizado") @db.Decimal(14, 2)
  percentualExecutado Decimal @map("percentual_executado") @db.Decimal(7, 2)
  mostrarNoRelatorio  Boolean @default(true) @map("mostrar_no_relatorio")
  observacao          String? @db.Text

  relatorio Relatorio @relation(fields: [relatorioId], references: [id], onDelete: Cascade)

  @@index([relatorioId])
  @@map("itens_relatorio")
}

model FotoRelatorio {
  id           String  @id @default(uuid()) @db.Uuid
  relatorioId  String  @map("relatorio_id") @db.Uuid
  ordem        Int
  imagemBase64 String? @map("imagem_base64") @db.Text
  legenda      String? @db.Text

  relatorio Relatorio @relation(fields: [relatorioId], references: [id], onDelete: Cascade)

  @@index([relatorioId])
  @@map("fotos_relatorio")
}

model RelatorioBackup {
  id              String        @id @default(uuid()) @db.Uuid
  relatorioId     String        @map("relatorio_id") @db.Uuid
  obraId          String        @map("obra_id")
  tipo            TipoRelatorio
  dados           Json
  excluidoPorId   String        @map("excluido_por_id")
  excluidoPorNome String        @map("excluido_por_nome")
  excluidoEm      DateTime      @default(now()) @map("excluido_em")

  @@index([obraId, excluidoEm])
  @@index([relatorioId])
  @@map("relatorios_backup")
}

model PasswordReset {
  id        String   @id @default(cuid())
  usuarioId String
  token     String   @unique
  expiraEm  DateTime
  usado     Boolean  @default(false)
  criadoEm  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([token])
}
