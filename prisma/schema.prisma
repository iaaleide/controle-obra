generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Perfil {
  ADMIN
  MESTRE
  VISITANTE
}

enum AcaoPresencaHistorico {
  CRIACAO
  ALTERACAO
}

model Usuario {
  id           String   @id @default(cuid())
  login        String   @unique
  senhaHash    String
  nome         String
  perfil       Perfil   @default(VISITANTE)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  resetTokens        PasswordReset[]
  historicoPresencas PresencaHistorico[]
}

model Obra {
  id           String   @id @default(cuid())
  nome         String
  endereco     String?
  descricao    String?
  ativa        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  alocacoes FuncionarioObra[]
  presencas Presenca[]
}

model Funcionario {
  id           String   @id @default(cuid())
  nome         String
  cargo        String?
  telefone     String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  obras     FuncionarioObra[]
  presencas Presenca[]
}

model FuncionarioObra {
  funcionarioId String
  obraId        String
  criadoEm      DateTime @default(now())

  funcionario Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  obra        Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@id([funcionarioId, obraId])
  @@index([obraId])
}

model Presenca {
  id            String   @id @default(cuid())
  funcionarioId String
  obraId        String
  data          DateTime @db.Date
  presente      Boolean  @default(false)
  observacao    String?  @db.VarChar(500)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  funcionario Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  obra        Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)
  historico   PresencaHistorico[]

  @@unique([funcionarioId, data])
  @@index([obraId, data])
}

model PresencaHistorico {
  id                 String                @id @default(cuid())
  presencaId         String
  funcionarioId      String
  obraId             String
  data               DateTime              @db.Date
  presente           Boolean
  observacao         String?               @db.VarChar(500)
  acao               AcaoPresencaHistorico
  usuarioId          String
  usuarioNome        String
  usuarioPerfil      Perfil
  presenteAnterior   Boolean?
  observacaoAnterior String?               @db.VarChar(500)
  obraIdAnterior     String?
  criadoEm           DateTime              @default(now())

  presenca Presenca @relation(fields: [presencaId], references: [id], onDelete: Cascade)
  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([presencaId])
  @@index([funcionarioId, data])
}

model PasswordReset {
  id        String   @id @default(cuid())
  usuarioId String
  token     String   @unique
  expiraEm  DateTime
  usado     Boolean  @default(false)
  criadoEm  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([token])
}
