# Cliente Supabase (Dashboard → Connect → API keys)
NEXT_PUBLIC_SUPABASE_URL="https://uqfkczlgfzjfrglfweqw.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sua-publishable-key"
#
# No painel Supabase: Project Settings → Database → Connection string
#
# Projeto: https://uqfkczlgfzjfrglfweqw.supabase.co
# Supabase → Project Settings → Database → Connection string → URI
#
# Local: conexão DIRECT (porta 5432).
# Vercel (IPv4): use Session Pooler em DATABASE_URL; DIRECT_URL = conexão direta.
# 1) DATABASE_URL = runtime (pooler na Vercel, direct local)
# 2) DIRECT_URL   = Prisma migrate/push (conexão direta)

DATABASE_URL="postgresql://postgres:[SUA-SENHA]@db.uqfkczlgfzjfrglfweqw.supabase.co:5432/postgres?sslmode=require&connection_limit=1"

DIRECT_URL="postgresql://postgres:[SUA-SENHA]@db.uqfkczlgfzjfrglfweqw.supabase.co:5432/postgres?sslmode=require&connect_timeout=30"

# Segredo para tokens JWT (gere uma string longa e aleatória)
JWT_SECRET="troque-por-uma-chave-secreta-muito-longa"

# URL do app (necessário para links de recuperação de senha)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# E-mails autorizados para recuperação de senha (ambos recebem o link)
RECOVERY_EMAIL_1="atomica.eng@gmail.com"
RECOVERY_EMAIL_2="ia.aleide@gmail.com"

# SMTP para envio de e-mails (Gmail, Resend, etc.)
