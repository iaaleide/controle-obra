# ===========================================
# SUPABASE — copie para .env e preencha os valores
# Login Supabase: ia.aleide@gmail.com
# ===========================================
#
# No painel Supabase: Project Settings → Database → Connection string
#
# 1) DATABASE_URL = modo "Transaction" (pooler, porta 6543) — usado pelo app
# 2) DIRECT_URL   = modo "Session" ou "Direct" (porta 5432) — usado pelo Prisma migrate/push

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[SUA-SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true"

DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[SUA-SENHA]@aws-0-[REGIAO].pooler.supabase.com:5432/postgres"

# Segredo para tokens JWT (gere uma string longa e aleatória)
JWT_SECRET="troque-por-uma-chave-secreta-muito-longa"

# URL do app (necessário para links de recuperação de senha)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# E-mails autorizados para recuperação de senha (ambos recebem o link)
RECOVERY_EMAIL_1="atomica.eng@gmail.com"
RECOVERY_EMAIL_2="ia.aleide@gmail.com"

# SMTP para envio de e-mails (Gmail, Resend, etc.)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_FROM="Controle Obra <seu-email@gmail.com>"
